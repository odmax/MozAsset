generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ASSET_MANAGER
  DEPARTMENT_MANAGER
  EMPLOYEE
}

enum AppearanceMode {
  LIGHT
  DARK
  SYSTEM
}

enum InternalRole {
  OWNER
  PLATFORM_ADMIN
  SUPPORT_ADMIN
  FINANCE_ADMIN
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SenderType {
  USER
  BOT
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  TRIALING
}

enum BillingProvider {
  STRIPE
  PAYSTACK
  NONE
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  IN_REPAIR
  RETIRED
  DISPOSED
  LOST
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  NEEDS_REPAIR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  TRANSFER
  CHECK_IN
  CHECK_OUT
  MAINTENANCE
  RETIRE
  DISPOSE
  ACTIVATE
  DEACTIVATE
  PASSWORD_RESET
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            Role      @default(EMPLOYEE)
  plan            Plan      @default(FREE)
  assetLimit      Int       @default(50)
  departmentLimit Int       @default(1)
  locationLimit   Int       @default(1)
  userLimit       Int       @default(3)
  onBoardingComplete Boolean @default(false)
  
  subscriptionStatus   SubscriptionStatus @default(ACTIVE)
  billingProvider      BillingProvider    @default(NONE)
  billingCustomerId    String?
  billingSubscriptionId String?
  billingPeriodStart   DateTime?
  billingPeriodEnd     DateTime?
  canceledAt           DateTime?
  lastPaymentAt       DateTime?
  
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  isActive        Boolean   @default(true)
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  resetToken      String?
  resetTokenExpiry DateTime?
  emailVerificationToken String?
  emailVerifiedAt DateTime?
  
  appearanceMode  AppearanceMode @default(SYSTEM)
  themeColor     String?        @default("#222222")
  companyLogoUrl String?

  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  ownedOrganization Organization? @relation("OrganizationOwner")

  accounts        Account[]
  sessions        Session[]
  assets          Asset[]          @relation("AssignedAssets")
  assignedAssets  AssetAssignment[]
  auditLogs       AuditLog[]
  maintenances    Maintenance[]
  managedDepartments Department[] @relation("DepartmentManager")
  invoices        Invoice[]
  payments       Payment[]
  supportTickets SupportTicket[]

  @@index([email])
  @@index([departmentId])
  @@index([organizationId])
}

model Organization {
  id              String    @id @default(cuid())
  name            String    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownerId         String    @unique
  owner           User       @relation("OrganizationOwner", fields: [ownerId], references: [id])

  users           User[]
  departments     Department[]
  locations       Location[]
  assets          Asset[]
  categories      Category[]
  vendors         Vendor[]

  plan            Plan      @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  billingProvider BillingProvider @default(NONE)
  billingCustomerId String?
  billingSubscriptionId String?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  canceledAt       DateTime?

  @@index([ownerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  assets      Asset[]

  @@unique([name, organizationId])
  @@index([name])
  @@index([organizationId])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  managerId   String?
  manager     User?    @relation("DepartmentManager", fields: [managerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  users       User[]
  locations   Location[]
  assets      Asset[]

  @@index([name])
  @@index([code])
  @@index([organizationId])
}

model Location {
  id           String     @id @default(cuid())
  name         String
  address      String?
  building     String?
  floor        String?
  room         String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  assets       Asset[]

  @@unique([name, departmentId])
  @@index([departmentId])
  @@index([organizationId])
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  assets      Asset[]

  @@unique([name, organizationId])
  @@index([name])
  @@index([organizationId])
}

model Asset {
  id              String         @id @default(cuid())
  assetTag        String         @unique
  name            String
  description     String?
  serialNumber    String?
  model           String?
  brand           String?
  status          AssetStatus    @default(AVAILABLE)
  condition       AssetCondition @default(GOOD)
  
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id])
  
  locationId      String?
  location        Location?      @relation(fields: [locationId], references: [id])
  
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  
  assignedToId    String?
  assignedTo      User?          @relation("AssignedAssets", fields: [assignedToId], references: [id])
  
  vendorId        String?
  vendor          Vendor?        @relation(fields: [vendorId], references: [id])
  
  purchaseDate    DateTime?
  purchaseCost    Decimal?      @db.Decimal(12, 2)
  warrantyExpiry  DateTime?
  notes           String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  assignments     AssetAssignment[]
  transfers       AssetTransfer[]
  maintenances    Maintenance[]
  checkIns        CheckInOut[]
  auditLogs       AuditLog[]

  @@index([assetTag])
  @@index([name])
  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([assignedToId])
}

model AssetAssignment {
  id          String    @id @default(cuid())
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  assignedBy  String
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?
  notes       String?   @db.Text

  @@index([assetId])
  @@index([userId])
}

model AssetTransfer {
  id              String   @id @default(cuid())
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromDepartmentId String?
  toDepartmentId   String
  fromLocationId   String?
  toLocationId     String?
  fromUserId       String?
  toUserId         String?
  transferredBy    String
  transferredAt    DateTime @default(now())
  notes           String?   @db.Text

  @@index([assetId])
}

model Maintenance {
  id            String          @id @default(cuid())
  assetId       String
  asset         Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type          String
  description   String          @db.Text
  performedBy   String
  performedByUser User          @relation(fields: [performedBy], references: [id])
  performedAt   DateTime        @default(now())
  cost          Decimal?        @db.Decimal(10, 2)
  vendorId      String?
  nextDueDate   DateTime?
  status        String          @default("COMPLETED")
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([assetId])
  @@index([performedBy])
}

model CheckInOut {
  id          String    @id @default(cuid())
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId      String
  type        String    // CHECK_IN or CHECK_OUT
  checkedAt   DateTime  @default(now())
  notes       String?   @db.Text
  condition   AssetCondition?
  createdAt   DateTime  @default(now())

  @@index([assetId])
  @@index([userId])
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String
  entityId    String
  assetId     String?
  asset       Asset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  changes     Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([assetId])
  @@index([userId])
  @@index([createdAt])
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  company    String?
  phone      String?
  message    String   @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal   @db.Decimal(10, 2)
  currency    String   @default("USD")
  status      String   @default("PENDING")
  provider    BillingProvider @default(NONE)
  providerInvoiceId String?
  description String?
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Decimal   @db.Decimal(10, 2)
  currency  String   @default("ZAR")
  status    String   @default("PENDING")
  provider  String   @default("NONE")
  providerPaymentId String?
  plan      String?
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerPaymentId])
  @@index([createdAt])
}

model InternalAdmin {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  password  String
  role      InternalRole  @default(PLATFORM_ADMIN)
  isActive  Boolean       @default(true)
  lastLogin DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  assignedTickets SupportTicket[]

  @@index([email])
}

model SupportTicket {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  organizationId  String?
  subject        String
  category       String
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  assignedAdminId String?
  assignedAdmin  InternalAdmin? @relation(fields: [assignedAdminId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  messages       SupportMessage[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([assignedAdminId])
  @@index([createdAt])
}

model SupportMessage {
  id           String     @id @default(cuid())
  ticketId     String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  senderType  SenderType @default(USER)
  senderUserId String?
  senderAdminId String?
  message     String     @db.Text
  createdAt   DateTime   @default(now())

  @@index([ticketId])
  @@index([senderUserId])
  @@index([senderAdminId])
}
