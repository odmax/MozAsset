# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/asset_management?schema=public"

# ===========================================
# AUTHENTICATION
# ===========================================
# For local development: http://localhost:3000
# For Vercel Preview: https://[your-project]-vercel-preview-url.vercel.app
# For Vercel Production: https://[your-production-domain].com
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# ===========================================
# EMAIL PROVIDER
# Options: console (dev only), smtp, resend, brevo
# ===========================================
EMAIL_PROVIDER=console

# SMTP Configuration (when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Email sender (all providers)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=MozAssets

# ===========================================
# PAYFAST (Payment Gateway)
# ===========================================
# Mode: sandbox or live
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# URLs (use preview/production URLs in Vercel)
# Sandbox: https://[your-project]-vercel-preview-url.vercel.app
# Production: https://[your-production-domain].com
PAYFAST_ITN_URL=http://localhost:3000/api/payfast/itn
PAYFAST_RETURN_URL=http://localhost:3000/checkout/success
PAYFAST_CANCEL_URL=http://localhost:3000/checkout/cancel